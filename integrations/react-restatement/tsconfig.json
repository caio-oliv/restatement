{
	"extends": ["../../rules.tsconfig.json"],
	"compilerOptions": {
		"composite": true,
		"incremental": true,

		"rootDir": "./",
		"outDir": "dist",
		"paths": {
			"@/*": ["./src/*"],
			"@test/*": ["./test/*"]
		},

		"jsx": "preserve"
	},
	"include": ["src/**/*", "test/**/*", "vite.config.ts"],
	"exclude": ["node_modules/**", "dist/**", "coverage/**"]
}
